{
  "name": "pi-web-codex",
  "version": "0.1.0",
  "description": "A local Web Host for Pi coding-agent workflows.",
  "license": "MIT",
  "bin": {
    "pi-web-codex": "./bin/pi-web-codex.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "turbo build && node scripts/assemble-dist.mjs",
    "dev": "turbo dev --filter=web --filter=@workspace/worker-pi --filter=@workspace/worker-pi-client --filter=@pi-web-codex/extension-sdk --filter=pi-codex-conversation-webui --filter=pi-codex-conversion-webui --filter=pi-web-access-webui",
    "lint": "turbo lint",
    "test": "tsx --tsconfig apps/web/tsconfig.json --conditions=react-server --test apps/web/lib/*.test.ts packages/extension-sdk/src/*.test.ts packages/worker-common/src/*.test.ts webui-extensions/builtin/*/src/*.test.ts",
    "release:verify": "pnpm build && node scripts/verify-release.mjs",
    "format": "turbo format && prettier --write \"bin/**/*.mjs\" \"scripts/**/*.mjs\"",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.4",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
