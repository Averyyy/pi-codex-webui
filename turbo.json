{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "APPDATA",
    "HOSTNAME",
    "NODE_ENV",
    "PI_CODING_AGENT_DIR",
    "PI_CODING_AGENT_SESSION_DIR",
    "PI_SERVER_AUTH_TOKEN",
    "PI_SERVER_MODE",
    "PI_SERVER_URL",
    "PI_WEB_CODEX_CONFIG_DIR",
    "PI_WEB_CODEX_BUILTIN_EXTENSION_ROOT",
    "PI_WEB_CODEX_PI_WORKER_PATH",
    "PI_WEB_CODEX_PI_CLIENT_WORKER_PATH",
    "PI_WEB_CODEX_WEBUI_EXTENSION_PATHS",
    "PORT",
    "XDG_CONFIG_HOME"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^build"],
      "persistent": true
    }
  }
}
